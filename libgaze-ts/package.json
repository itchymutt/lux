{
  "name": "libgaze-ts",
  "version": "0.1.0",
  "description": "See what your code does to the world before it runs. Static effect analysis for TypeScript.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "libgaze-ts": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test test/run.js",
    "bench": "node dist/bench/run.js"
  },
  "dependencies": {
    "oxc-parser": "^0.72.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "dist/src",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/itchymutt/gaze",
    "directory": "libgaze-ts"
  },
  "homepage": "https://github.com/itchymutt/gaze/tree/main/libgaze-ts",
  "bugs": "https://github.com/itchymutt/gaze/issues",
  "license": "MIT",
  "author": "Roberta Carraro",
  "keywords": [
    "effects",
    "static-analysis",
    "typescript",
    "security",
    "ai-safety",
    "linting"
  ],
  "engines": {
    "node": ">=18"
  }
}
